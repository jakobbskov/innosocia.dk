---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const ideer = await getCollection("ideer");

  return ideer.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allIdeer = await getCollection("ideer");
const relatedIdeer = allIdeer.filter((entry) =>
  post.data.relatedIdeer?.includes(entry.data.slug)
);
---

<BaseLayout title={`${post.data.title} | Innosocia`} description={post.data.description}>
  <Header />

  <section class="hero">
    <div class="wrapper">
      <p class="eyebrow">Idé</p>
      <h1>{post.data.title}</h1>
      <p class="muted">{post.data.description}</p>

      <div class="meta" style="margin-top: 1rem;">
        <span>{post.data.date}</span>
        {post.data.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="reading">
      <h2>Hvorfor teksten findes</h2>
      <p>{post.data.why}</p>
    </div>
  </section>

  <section class="section">
    <div class="reading">
      <h2>Teksten</h2>
      <Content />
    </div>
  </section>

  {relatedIdeer.length > 0 && (
    <section class="section">
      <div class="wrapper">
        <div class="section-head">
          <h2>Relaterede idéer</h2>
          <p class="muted">
            Andre tekster med beslægtede spørgsmål og perspektiver.
          </p>
        </div>

        <div class="grid grid-2">
          {relatedIdeer.map((entry) => <ArticleCard post={entry} />)}
        </div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>
