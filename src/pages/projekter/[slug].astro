---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projekter = await getCollection("projekter");

  return projekter.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const allProjects = await getCollection("projekter");
const relatedProjects = allProjects.filter((entry) =>
  project.data.relatedProjects?.includes(entry.data.slug)
);
---

<BaseLayout title={`${project.data.title} | Innosocia`} description={project.data.summary}>
  <Header />

  <section class="hero">
    <div class="wrapper">
      <p class="eyebrow">Projekt</p>
      <h1>{project.data.title}</h1>
      <p class="muted">{project.data.summary}</p>

      <div class="meta" style="margin-top: 1rem;">
        <span>{project.data.date}</span>
        <span>Status: {project.data.status}</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="reading">
      <h2>Hvorfor projektet findes</h2>
      <p>{project.data.why}</p>
    </div>
  </section>

  {project.data.direction?.length > 0 && (
    <section class="section">
      <div class="reading">
        <h2>Retning</h2>
        <ul>
          {project.data.direction.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>
  )}

  <section class="section">
    <div class="reading">
      <h2>Uddybning</h2>
      <Content />
    </div>
  </section>

  {relatedProjects.length > 0 && (
    <section class="section">
      <div class="wrapper">
        <div class="section-head">
          <h2>Relaterede projekter</h2>
          <p class="muted">
            Andre projekter i samme udviklingsspor eller økosystem.
          </p>
        </div>

        <div class="grid grid-2">
          {relatedProjects.map((entry) => <ProjectCard project={entry} />)}
        </div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>
