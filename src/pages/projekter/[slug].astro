---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projekter = await getCollection("projekter");

  return projekter.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | Innosocia`} description={project.data.summary}>
  <div class="wrapper">
    <p style="color:#2f5d50; font-weight:600;">Projekt</p>
    <h1>{project.data.title}</h1>

    <p style="color:#5d675f;">
      {project.data.date} · {project.data.status}
    </p>

    <hr />

    <Content />
  </div>
</BaseLayout>
