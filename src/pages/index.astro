---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

import AppCard from "../components/AppCard.astro";
import ArticleCard from "../components/ArticleCard.astro";
import ProjectCard from "../components/ProjectCard.astro";

const apps = await getCollection("apps");
const ideer = await getCollection("ideer");
const projekter = await getCollection("projekter");

const featuredApps = apps.filter((a) => a.data.featured);
const featuredIdeer = ideer.filter((i) => i.data.featured);
const featuredProjekter = projekter.filter((p) => p.data.featured);
---
<BaseLayout
  title="Innosocia"
  description="Digitale værktøjer med rygrad. Apps, idéer og projekter om local-first software, digital suverænitet og rolig teknologi."
>

  <section class="hero">
    <div class="wrapper">
      <p class="eyebrow">Innosocia</p>

      <h1>
        Digitale værktøjer med rygrad
      </h1>

      <p class="lead">
        Innosocia er et eksperimentarium for rolig teknologi, local-first software
        og værktøjer der styrker menneskers dømmekraft i stedet for at erstatte den.
      </p>

      <p class="muted">
        Her samles apps, idéer og projekter om digital suverænitet,
        forståelig systemlogik og mere robuste digitale arbejdsformer.
      </p>

      <div class="button-row">
        <a class="button primary" href="/apps/">Udforsk apps</a>
        <a class="button" href="/ideer/">Læs idéer</a>
        <a class="button" href="/projekter/">Se projekter</a>
      </div>
    </div>
  </section>

  <section class="section">
  <div class="wrapper reading">
    <h2>Hvad Innosocia er</h2>

    <p>
      Innosocia er et lille digitalt laboratorium for ideer og værktøjer,
      der forsøger at tage digital suverænitet alvorligt.
    </p>

    <p>
      I stedet for at bygge endnu en platform, handler det om at udvikle
      simple, forklarbare systemer som mennesker faktisk kan forstå,
      vedligeholde og bruge over lang tid.
    </p>
  </div>
</section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Apps</h2>
        <p class="muted">
          Sovereign-apps bygget med fokus på autonomi, lokal data og forståelig logik.
        </p>
        <p><a href="/apps/">Se alle apps →</a></p>
      </div>

      <div class="grid grid-3">
        {featuredApps.map((app) => <AppCard app={app} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Idéer</h2>
        <p class="muted">
          Essays og refleksioner om digital suverænitet, local-first software og
          rolige systemer.
        </p>
        <p><a href="/ideer/">Se alle idéer →</a></p>
      </div>

      <div class="grid grid-2">
        {featuredIdeer.map((post) => <ArticleCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="section">
  <div class="wrapper reading">
    <h2>Hvorfor det findes</h2>

    <p>
      Meget moderne software er bygget omkring platformafhængighed,
      abonnementer og lukkede systemer.
    </p>

    <p>
      Det skaber effektive tjenester, men også skrøbelige digitale
      økosystemer, hvor brugere mister kontrol over data,
      værktøjer og arbejdsgange.
    </p>

    <p>
      Innosocia er et forsøg på at undersøge et andet spor:
      local-first software, mere gennemsigtig logik og værktøjer
      der hjælper mennesker med at tænke klarere i stedet for
      at gøre dem afhængige af endnu et dashboard.
    </p>
  </div>
</section>

  <section class="section">
  <div class="wrapper">
    <div class="section-head">
      <h2>Hvad der bygges her</h2>
      <p class="muted">
        Innosocia samler tre typer arbejde.
      </p>
    </div>

    <div class="grid grid-3">

      <div class="card">
        <h3><a href="/apps/">Apps</a></h3>
        <p class="muted">
          Sovereign-apps til økonomi, træning og praktisk
          hverdag – bygget med local-first logik og
          forklarbare beslutningssystemer.
        </p>
      </div>

      <div class="card">
        <h3><a href="/ideer/">Idéer</a></h3>
        <p class="muted">
          Essays og refleksioner om digital suverænitet,
          local-first software og mere robuste digitale
          arbejdsformer.
        </p>
      </div>

      <div class="card">
        <h3><a href="/projekter/">Projekter</a></h3>
        <p class="muted">
          Konkrete udviklingsspor hvor ideerne omsættes
          til systemer, værktøjer og eksperimenter.
        </p>
      </div>

    </div>
  </div>
</section>

  <section class="section">
  <div class="wrapper reading">
    <h2>Hvorfor det er værd at følge</h2>

    <p>
      Digital suverænitet bliver ofte diskuteret i abstrakte
      politiske eller teknologiske termer.
    </p>

    <p>
      Innosocia forsøger i stedet at arbejde nedefra:
      ved at bygge konkrete værktøjer, skrive tydelige
      forklaringer og afprøve alternative digitale
      arbejdsformer i praksis.
    </p>

    <p>
      Hvis du interesserer dig for local-first software,
      forklarbar teknologi og mere robuste digitale systemer,
      er dette stedet hvor de ideer bliver testet i virkeligheden.
    </p>
  </div>
</section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Projekter</h2>
        <p class="muted">
          Praktiske initiativer, prototyper og forsøg på at bygge noget mindre dumt
          end standardmodellen.
        </p>
        <p><a href="/projekter/">Se alle projekter →</a></p>
      </div>

      <div class="grid grid-2">
        {featuredProjekter.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Find rundt</h2>
        <p class="muted">
          Direkte adgang til de vigtigste sider på sitet.
        </p>
      </div>

      <div class="grid grid-3">
        <div class="card">
          <h3><a href="/apps/">Apps</a></h3>
          <p class="muted">Oversigt over Sovereign-apps og værktøjer.</p>
        </div>

        <div class="card">
          <h3><a href="/ideer/">Idéer</a></h3>
          <p class="muted">Tekster om digital suverænitet og local-first software.</p>
        </div>

        <div class="card">
          <h3><a href="/projekter/">Projekter</a></h3>
          <p class="muted">Initiativer, prototyper og udviklingsspor.</p>
        </div>

        <div class="card">
          <h3><a href="/principper/">Principper</a></h3>
          <p class="muted">Grundidéer og arbejdsprincipper bag Innosocia.</p>
        </div>

        <div class="card">
          <h3><a href="/om/">Om</a></h3>
          <p class="muted">Baggrund, formål og retning for Innosocia.</p>
        </div>

        <div class="card">
          <h3><a href="/kontakt/">Kontakt</a></h3>
          <p class="muted">Kontaktoplysninger og muligheder for henvendelse.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
