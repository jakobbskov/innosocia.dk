---
import BaseLayout from "../layouts/BaseLayout.astro";
import RealityStrip from "../components/RealityStrip.astro";
import HeroBackground from "../components/HeroBackground.astro";
import HeroSystemCard from "../components/HeroSystemCard.astro";
import { getCollection } from "astro:content";

import AppCard from "../components/AppCard.astro";
import ArticleCard from "../components/ArticleCard.astro";
import ProjectCard from "../components/ProjectCard.astro";

const apps = await getCollection("apps");
const ideer = await getCollection("ideer");
const projekter = await getCollection("projekter");

const featuredApps = apps.filter((a) => a.data.featured);
const featuredIdeer = ideer.filter((i) => i.data.featured);
const featuredProjekter = projekter.filter((p) => p.data.featured);
---

<BaseLayout
  title="Innosocia"
  description="Digitale værktøjer med mindre afhængighed. Apps, idéer og projekter om local-first software, digital suverænitet og forklarbar teknologi."
>
  <section class="hero hero--with-bg">
    <HeroBackground />

    <div class="wrapper hero-layout">
      <div class="hero-copy">
        <p class="eyebrow">Innosocia</p>

        <h1>Digitale værktøjer med mindre afhængighed</h1>

        <p class="muted" style="font-size:1.15rem; max-width:60ch;">
          Innosocia bygger små, forklarbare apps og digitale arbejdsgange med fokus på
          local-first retning, mindre digital støj og mere plads til menneskelig dømmekraft.
        </p>

        <p class="muted" style="max-width:60ch;">
          Her kan du se, hvad der findes nu, hvilke principper det bygger på,
          og hvordan organisationer kan samarbejde om mere robuste digitale løsninger.
        </p>

        <div class="button-row">
          <a class="button primary" href="/apps/">Se apps</a>
          <a class="button" href="/samarbejde/">Se samarbejde</a>
          <a class="button" href="/status/">Se status</a>
        </div>

        <RealityStrip />
      </div>

      <HeroSystemCard />
    </div>
  </section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Kort fortalt</h2>
        <p class="muted">
          Innosocia er et lille software- og udviklingsspor for mere forståelige digitale værktøjer.
        </p>
      </div>

      <div class="grid grid-3">
        <div class="card">
          <h3>Hvad findes nu?</h3>
          <p class="muted">
            Et offentligt site, app-sider, status, principper, samarbejdsside og en beta af Sovereign Strength.
          </p>
          <p><a href="/status/">Se status →</a></p>
        </div>

        <div class="card">
          <h3>Hvorfor er det anderledes?</h3>
          <p class="muted">
            Fokus er local-first retning, forklarbar logik, lav afhængighed og digitale værktøjer, der hjælper mere end de forstyrrer.
          </p>
          <p><a href="/principper/">Læs principper →</a></p>
        </div>

        <div class="card">
          <h3>Hvad kan du gøre?</h3>
          <p class="muted">
            Se apps, læs idéerne eller brug samarbejdssiden, hvis du arbejder med digitale løsninger i en organisation.
          </p>
          <p><a href="/samarbejde/">Se samarbejde →</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Apps</h2>
        <p class="muted">
          Sovereign-apps bygget med fokus på autonomi, lokal data og forståelig logik.
        </p>
        <p><a href="/apps/">Se alle apps →</a></p>
      </div>

      <div class="grid grid-3">
        {featuredApps.map((app) => <AppCard app={app} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Idéer</h2>
        <p class="muted">
          Essays og refleksioner om digital suverænitet, local-first software og rolige systemer.
        </p>
        <p><a href="/ideer/">Se alle idéer →</a></p>
      </div>

      <div class="grid grid-2">
        {featuredIdeer.map((post) => <ArticleCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Projekter</h2>
        <p class="muted">
          Praktiske initiativer, prototyper og forsøg på at bygge noget mindre dumt
          end standardmodellen.
        </p>
        <p><a href="/projekter/">Se alle projekter →</a></p>
      </div>

      <div class="grid grid-2">
        {featuredProjekter.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrapper reading">
      <h2>Hvorfor det er værd at følge</h2>

      <p>
        Digital suverænitet bliver ofte diskuteret i abstrakte
        politiske eller teknologiske termer.
      </p>

      <p>
        Innosocia forsøger i stedet at arbejde nedefra:
        ved at bygge konkrete værktøjer, skrive tydelige
        forklaringer og afprøve alternative digitale
        arbejdsformer i praksis.
      </p>

      <p>
        Hvis du interesserer dig for local-first software,
        forklarbar teknologi og mere robuste digitale systemer,
        er dette stedet hvor de idéer bliver testet i virkeligheden.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Se arbejdet</h2>
        <p class="muted">
          Innosocia skal kunne efterprøves gennem status, kildekode, screenshots hvor de findes og teknisk dokumentation.
        </p>
      </div>

      <div class="grid grid-3">
        <div class="card">
          <h3><a href="/status/">Status</a></h3>
          <p class="muted">
            Se konkrete ændringer, deploys og hvad der faktisk er flyttet på sitet.
          </p>
        </div>

        <div class="card">
          <h3><a href="/downloads/">Ressourcer</a></h3>
          <p class="muted">
            Find GitHub-links, download-status, dokumentation og historiske udviklingsnoter.
          </p>
        </div>

        <div class="card">
          <h3><a href="/architecture/">Arkitektur</a></h3>
          <p class="muted">
            Se hvordan sitet, apps, self-hosting og dokumentation hænger teknisk sammen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrapper">
      <div class="section-head">
        <h2>Næste skridt</h2>
        <p class="muted">
          Start med det mest konkrete, læs principperne bag, eller se hvordan et samarbejde kan begynde.
        </p>
      </div>

      <div class="grid grid-3">
        <div class="card">
          <h3><a href="/apps/">Se apps</a></h3>
          <p class="muted">
            Gå direkte til Sovereign-apps og de konkrete værktøjer,
            der udvikles under Innosocia.
          </p>
        </div>

        <div class="card">
          <h3><a href="/principper/">Læs principper</a></h3>
          <p class="muted">
            Få den korte version af retningen: local-first, forståelig logik,
            mindre digital støj og lav afhængighed.
          </p>
        </div>

        <div class="card">
          <h3><a href="/samarbejde/">Se samarbejde</a></h3>
          <p class="muted">
            Se hvordan kommuner, NGO’er, foreninger og små organisationer kan bruge Innosocia som sparrings- og udviklingsspor.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
