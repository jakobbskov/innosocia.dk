---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AppCard from "../../components/AppCard.astro";
import ShareBar from "../../components/ShareBar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const apps = await getCollection("apps");

  return apps.map((app) => ({
    params: { slug: app.data.slug },
    props: { app },
  }));
}

const { app } = Astro.props;
const { Content } = await render(app);

const allApps = await getCollection("apps");
const relatedApps = allApps.filter((entry) =>
  app.data.relatedApps?.includes(entry.data.slug)
);

const pageUrl = `https://innosocia.dk/apps/${app.data.slug}/`;
const pageImage = "https://innosocia.dk/social-preview-default.png";
---

<BaseLayout
  title={`${app.data.title} | Innosocia`}
  description={app.data.summary}
  image={pageImage}
  canonical={pageUrl}
>
  <section class="hero">
    <div class="wrapper">
      <p class="eyebrow">App</p>
      <h1>{app.data.title}</h1>
      <p>{app.data.tagline}</p>

      <div class="meta" style="margin-top: 1rem;">
        <span>Status: {app.data.status}</span>
        <span>Opdateret: {app.data.updatedAt}</span>
        {app.data.license && <span>Licens: {app.data.license}</span>}
        {app.data.repoUrl && (
          <span>
            Kode: <a href={app.data.repoUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
          </span>
        )}
      </div>

      <p class="muted" style="margin-top: 1rem;">{app.data.summary}</p>

      <ShareBar
        url={pageUrl}
        title={app.data.title}
        text={app.data.summary}
      />
    </div>
  </section>

  {(app.data.availabilityText || app.data.downloadStatus || app.data.nextStep || app.data.primaryUrl) && (
    <section class="section">
      <div class="wrapper">
        <div class="section-head">
          <h2>Kort status</h2>
          <p class="muted">
            Hvad kan man gøre med appen lige nu?
          </p>
        </div>

        <div class="grid grid-3">
          {app.data.availabilityText && (
            <div class="card">
              <h3>{app.data.availabilityLabel || "Status"}</h3>
              <p class="muted">{app.data.availabilityText}</p>
              {app.data.primaryUrl && (
                <p>
                  <a href={app.data.primaryUrl} target="_blank" rel="noopener noreferrer">
                    {app.data.primaryActionLabel || "Åbn app"}
                  </a>
                </p>
              )}
            </div>
          )}

          {app.data.downloadStatus && (
            <div class="card">
              <h3>Download</h3>
              <p class="muted">{app.data.downloadStatus}</p>
            </div>
          )}

          {app.data.nextStep && (
            <div class="card">
              <h3>Næste skridt</h3>
              <p class="muted">{app.data.nextStep}</p>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {app.data.screenshots?.length > 0 && (
    <section class="section">
      <div class="wrapper">
        <div class="section-head">
          <h2>Sådan ser appen ud</h2>
          <p class="muted">
            Tre nedslag i den aktuelle prototype.
          </p>
        </div>

        <div class="app-screenshot-grid">
          {app.data.screenshots.map((screenshot) => (
            <figure class="app-screenshot-card">
              <img
                src={screenshot.src}
                alt={screenshot.alt}
                loading="lazy"
              />
              <figcaption>
                <strong>{screenshot.title}</strong>
                <span>{screenshot.caption}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="reading">
      <Content />
    </div>
  </section>

  {app.data.solves?.length > 0 && (
    <section class="section">
      <div class="reading">
        <h2>Det appen prøver at løse</h2>
        <ul>
          {app.data.solves.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>
  )}

  {app.data.techDirection?.length > 0 && (
    <section class="section">
      <div class="reading">
        <h2>Teknologisk retning</h2>
        <ul>
          {app.data.techDirection.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>
  )}

  {relatedApps.length > 0 && (
    <section class="section">
      <div class="wrapper">
        <div class="section-head">
          <h2>Relaterede apps</h2>
          <p class="muted">
            Andre værktøjer i samme økosystem.
          </p>
        </div>

        <div class="grid grid-3">
          {relatedApps.map((entry) => <AppCard app={entry} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
